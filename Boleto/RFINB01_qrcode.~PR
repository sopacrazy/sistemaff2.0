Static Function RFINB01C()

	Local _nCnt   := 0
	Local _nPeso  := 2
	Local _nJ     := 1
	Local _nResto := 0

	For _nJ := Len(_cCampo) To 1 Step -1
		_nCnt  := _nCnt + Val(SUBSTR(_cCampo,_nJ,1))*_nPeso
		_nPeso :=_nPeso+1
		if _nPeso > 9
			_nPeso := 2
		endif
	Next _nJ

	_nResto:=(_ncnt%11)

	_nResto:=11 - _nResto

	if _nResto == 0 .or. _nResto==1 .or. _nResto > 9
		_nDigbar:='1'
	else
		_nDigbar:=Str(_nResto,1)
	endif

Return(_nDigbar)


Static Function Modulo10(cData)

	LOCAL L,D,P := 0
	LOCAL B     := .F.

	L := Len(cData)
	B := .T.
	D := 0

	While L > 0
		P := Val(SubStr(cData, L, 1))
		If (B)
			P := P * 2
			If P > 9
				P := P - 9
			End
		End
		D := D + P
		L := L - 1
		B := !B
	End

	D := 10 - (Mod(D,10))

	If D = 10
		D := 0
	End

Return(D)


Static Function Modulo11Nn(cData)
	LOCAL L, D, P,R := 0
	L := Len(cdata)
	D := 0
	P := 1
	While L > 0
		P := P + 1
		D := D + (Val(SubStr(cData, L, 1)) * P)
		If P = 9
			P := 1
		End
		L := L - 1
	End

	R := mod(D,11)
	If (R == 10)
		D := 1
	ElseIf (R == 0 .or. R == 1)
		D := 0
	Else
		D := (11 - R)
	End              

Return(D)


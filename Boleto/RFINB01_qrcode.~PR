Static Function yModulo10(cData)

	Local L	:= Len(cData)
	Local D	:= 0
	Local P := 0
	Local B	:= .T.

	While L > 0

		P := Val(SubStr(cData, L, 1))
	
		If (B)
			P := P * 2
			If P > 9
				P := P - 9
			EndIf
		EndIf
	
		D := D + P
		L := L - 1
		B := !B
	
	EndDo

	D := 10 - (Mod(D,10))

	If D = 10
		D := 0
	EndIf

Return(AllTrim(Str(D,1)))

